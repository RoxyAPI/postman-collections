{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"types": ["bun", "node"],
		"lib": ["ES2022"]
	},
	"include": ["scripts/**/*.ts"],
	"exclude": ["node_modules"]
}

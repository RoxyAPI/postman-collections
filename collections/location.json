								}
							],
							"body": "{\n  \"total\": 3,\n  \"limit\": 10,\n  \"offset\": 0,\n  \"cities\": [\n    {\n      \"city\": \"Berlin\",\n      \"province\": \"Berlin\",\n      \"country\": \"Germany\",\n      \"iso2\": \"DE\",\n      \"latitude\": 52.52,\n      \"longitude\": 13.405,\n      \"timezone\": \"Europe/Berlin\",\n      \"utcOffset\": 1,\n      \"population\": 3644826\n    },\n    {\n      \"city\": \"Berlin\",\n      \"province\": \"Berlin\",\n      \"country\": \"Germany\",\n      \"iso2\": \"DE\",\n      \"latitude\": 52.52,\n      \"longitude\": 13.405,\n      \"timezone\": \"Europe/Berlin\",\n      \"utcOffset\": 1,\n      \"population\": 3644826\n    }\n  ]\n}",
